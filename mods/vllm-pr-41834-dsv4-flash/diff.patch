+def test_compact_spec_type_dispatch() -> None:
+    """Verify CompactCPULoadStoreSpec and CPULoadStoreSpec are distinct types."""
+    addr = CompactCPUAddress(
+        byte_offset=0,
+        logical_length=64,
+        allocated_length=64,
