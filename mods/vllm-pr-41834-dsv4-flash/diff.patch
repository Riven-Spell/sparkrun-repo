+        assert torch.allclose(draft_probs[:, step, :], expected_probs, atol=1e-5)
+        assert (draft_probs[rows, step, tokens[:, step]] > 0).all()
+        prev = tokens[:, step]
+
+    assert torch.allclose(
+        draft_probs.sum(dim=-1),
+        torch.ones(batch, block, device=DEVICE_TYPE),
+        atol=1e-4,
+    )
