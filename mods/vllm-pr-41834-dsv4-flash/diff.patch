+def test_handler_descriptor_partial_chunk() -> None:
+    """Partial chunk geometry: block_idx=2 with block_size_factor=4."""
+    k_cfg = CompactSliceConfig(
+        offset_bytes=0,
+        real_bytes_per_gpu_block=80,
+        padded_bytes_per_gpu_block=100,
