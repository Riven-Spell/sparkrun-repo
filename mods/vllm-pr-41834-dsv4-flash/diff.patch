+            sample_logits,
+            sample_inv_temp,
+            is_greedy_i32,
+            tokens[:, step_idx],
+            draft_probs[:, step_idx, :],
+            scratch,
+            _next_fused_markov_seed(),
+            block_v=block_v,
+        )
+        prev_token_ids = tokens[:, step_idx]
+
+    return tokens, draft_probs
