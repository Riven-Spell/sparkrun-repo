+    cpu_to_gpu_dispatch = isinstance(compact_spec, CompactCPULoadStoreSpec)
+    assert cpu_to_gpu_dispatch is True
+
+    # Legacy path should not match compact.
+    assert not isinstance(legacy_spec, CompactCPULoadStoreSpec)
