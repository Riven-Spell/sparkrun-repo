+    )
+
+    _fill_compact_descriptor_buffers_numpy(
+        gpu_to_cpu=True,
+        plan=plan,
+        src_arr=src_buf,
+        dst_arr=dst_buf,
+        sizes_arr=sz_buf,
+    )
+
+    np.testing.assert_array_equal(src_buf, plan.gpu_ptrs)
+    np.testing.assert_array_equal(dst_buf, plan.cpu_ptrs)
+    np.testing.assert_array_equal(sz_buf, plan.sizes)
